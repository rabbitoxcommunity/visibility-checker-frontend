---
const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ?? "Nalar GPT"}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-slate-900 h-screen w-screen overflow-hidden flex m-0 p-0">
    <div class="w-full h-full bg-white flex overflow-hidden font-sans">
      <!-- LEFT SIDEBAR -->
      <div class="w-[72px] border-r border-slate-100 flex flex-col justify-between py-6 items-center shrink-0 bg-slate-50/30">
        <div class="flex flex-col items-center gap-8 w-full">
          <!-- Logo -->
          <a href="/" class="w-9 h-9 flex flex-wrap gap-[3px] p-[3px] justify-center items-center cursor-pointer">
            <div class="w-[13px] h-[13px] rounded-tl-[5px] rounded-tr-[5px] rounded-bl-[5px] rounded-br-[1px] bg-[#1a73e8]"></div>
            <div class="w-[13px] h-[13px] rounded-tl-[5px] rounded-tr-[5px] rounded-bl-[1px] rounded-br-[5px] bg-[#1a73e8]"></div>
            <div class="w-[13px] h-[13px] rounded-tl-[5px] rounded-tr-[1px] rounded-bl-[5px] rounded-br-[5px] bg-[#1a73e8]"></div>
            <div class="w-[13px] h-[13px] rounded-tl-[1px] rounded-tr-[5px] rounded-bl-[5px] rounded-br-[5px] bg-[#1a73e8]"></div>
          </a>

          <!-- Icons Stack -->
          <div class="flex flex-col items-center gap-5 w-full mt-4">
            <a href="/" class={`p-2 rounded-xl transition-all ${currentPath === "/" || currentPath === "" ? "text-[#1a73e8] bg-blue-50/50" : "text-slate-400 hover:text-[#1a73e8] hover:bg-blue-50/30"}`} title="Home">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                <polyline points="9 22 9 12 15 12 15 22" />
              </svg>
            </a>
            <a href="/about" class={`p-2 rounded-xl transition-all ${currentPath.startsWith("/about") ? "text-[#1a73e8] bg-blue-50/50" : "text-slate-400 hover:text-[#1a73e8] hover:bg-blue-50/30"}`} title="About">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <path d="M12 16v-4" />
                <path d="M12 8h.01" />
              </svg>
            </a>
            <a href="/pricing" class={`p-2 rounded-xl transition-all ${currentPath.startsWith("/pricing") ? "text-[#1a73e8] bg-blue-50/50" : "text-slate-400 hover:text-[#1a73e8] hover:bg-blue-50/30"}`} title="Pricing">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" x2="12" y1="2" y2="22" />
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
              </svg>
            </a>
            <a href="/terms" class={`p-2 rounded-xl transition-all ${currentPath.startsWith("/terms") ? "text-[#1a73e8] bg-blue-50/50" : "text-slate-400 hover:text-[#1a73e8] hover:bg-blue-50/30"}`} title="Terms of Service">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="16" x2="8" y1="13" y2="13" />
                <line x1="16" x2="8" y1="17" y2="17" />
                <line x1="10" x2="8" y1="9" y2="9" />
              </svg>
            </a>
            <a href="/privacy" class={`p-2 rounded-xl transition-all ${currentPath.startsWith("/privacy") ? "text-[#1a73e8] bg-blue-50/50" : "text-slate-400 hover:text-[#1a73e8] hover:bg-blue-50/30"}`} title="Privacy Policy">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="18" height="11" x="3" y="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
              </svg>
            </a>
            <a href="/settings" class={`p-2 rounded-xl transition-all ${currentPath.startsWith("/settings") ? "text-[#1a73e8] bg-blue-50/50" : "text-slate-400 hover:text-[#1a73e8] hover:bg-blue-50/30"}`} title="Settings">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3" />
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
              </svg>
            </a>
          </div>
        </div>

        <!-- User Initials Avatar -->
        <a href="/settings" class="w-9 h-9 rounded-full bg-[#bfdbfe]/60 text-[#1e3a8a] text-[13px] font-semibold flex items-center justify-center cursor-pointer hover:bg-[#bfdbfe] transition-colors" title="User Profile">
          AF
        </a>
      </div>

      <!-- MAIN CONTAINER -->
      <div class="flex-1 flex flex-col justify-between h-full bg-white relative">
        <!-- TOP HEADER -->
        <div class="h-14 border-b border-slate-100/80 px-6 flex items-center justify-between shrink-0">
          <!-- Dropdown Selector -->
          <div class="flex items-center gap-1.5 bg-slate-50 hover:bg-slate-100 transition-colors px-3 py-1.5 rounded-full text-[12px] font-semibold text-slate-700 cursor-pointer border border-slate-100">
            <span>Nalar GPT 4o</span>
            <svg class="w-3 h-3 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </div>

          <!-- Right Icons -->
          <div class="flex items-center gap-3.5">
            <a href="/" class="p-1 rounded hover:bg-slate-50 text-slate-400 hover:text-slate-600 transition-colors cursor-pointer" title="Reset Chat">
              <svg class="w-[17px] h-[17px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8" />
                <path d="M21 3v5h-5" />
                <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16" />
                <path d="M3 21v-5h5" />
              </svg>
            </a>
            <div class="h-4 w-[1px] bg-slate-200"></div>
            <button class="p-1 rounded hover:bg-slate-50 text-slate-400 hover:text-slate-600 transition-colors cursor-pointer" title="Notifications">
              <svg class="w-[17px] h-[17px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9" />
                <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0" />
              </svg>
            </button>
            <a href="/settings" class="p-1 rounded hover:bg-slate-50 text-slate-400 hover:text-slate-600 transition-colors cursor-pointer" title="Settings">
              <svg class="w-[17px] h-[17px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3" />
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
              </svg>
            </a>
          </div>
        </div>

        <!-- WORKSPACE MIDDLE BODY -->
        <div class="flex-1 overflow-y-auto px-6 md:px-12 py-8 w-full max-w-4xl mx-auto">
          <slot />
        </div>
      </div>
    </div>
  </body>
</html>
