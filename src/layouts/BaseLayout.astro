---
const { title, clean = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ?? "Nazar — Is your business seen by AI?"}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class={clean ? "bg-white text-slate-900 h-screen w-screen overflow-hidden flex" : "bg-slate-950/5 text-slate-900"}>
    {!clean && (
      <header class="border-b border-slate-200 bg-white/90 backdrop-blur-md">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
          <a href="/" class="text-lg font-semibold text-slate-900">Nazar</a>
          <nav class="flex flex-wrap gap-3 text-sm text-slate-600">
            <a href="/about" class="hover:text-slate-900">About</a>
            <a href="/pricing" class="hover:text-slate-900">Pricing</a>
            <a href="/terms" class="hover:text-slate-900">Terms</a>
            <a href="/privacy" class="hover:text-slate-900">Privacy</a>
          </nav>
        </div>
      </header>
    )}
    <main class={clean ? "w-full h-full" : "min-h-screen"}>
      <slot />
    </main>
  </body>
</html>
